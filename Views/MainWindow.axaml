<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Atelier.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
        x:Class="Atelier.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="Atelier"
        Icon="/Assets/atelier-icon.ico"
        Background="#0A0A0A"
        TransparencyLevelHint="Mica, AcrylicBlur"
        ExtendClientAreaToDecorationsHint="True"
        ExtendClientAreaTitleBarHeightHint="-1"
        FontFamily="avares://Atelier/Assets/Exo-VariableFont_wght.ttf#Exo, Inter, Segoe UI, Arial, sans-serif"
        DragDrop.AllowDrop="True">

    <Design.DataContext>
        <vm:MainWindowViewModel/>
    </Design.DataContext>

    <Grid RowDefinitions="Auto,*,Auto">
        <!-- Menu Bar Area -->
        <Border Grid.Row="0" Background="#060606" BorderBrush="#1A1A1A" BorderThickness="0,0,0,1" IsVisible="{Binding ShowControls}" Height="80" ClipToBounds="False">
            <Grid RowDefinitions="40,40">
                <!-- Dedicated Draggable Area (Top half) -->
                <Panel Grid.Row="0" Name="DragArea" Background="Transparent" IsHitTestVisible="True">
                    <TextBlock Text="ATELIER" HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,12,0,0" 
                               Foreground="White" FontSize="11" FontWeight="ExtraBold" IsHitTestVisible="False" LetterSpacing="3"/>
                </Panel>
                
                <!-- Menu Area (Bottom half, explicitly interactive) -->
                <Menu Grid.Row="1" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="15,0,0,0" Background="Transparent" ClipToBounds="False">
                    <MenuItem Header="_File">
                        <MenuItem Header="_Open..." Click="OpenFileName_Click" InputGesture="Ctrl+O"/>
                        <MenuItem Header="_Save As..." Click="SaveAs_Click" InputGesture="Ctrl+S"/>
                        <Separator/>
                        <MenuItem Header="File _Associations..." Click="FileAssociations_Click"/>
                        <Separator/>
                        <MenuItem Header="_Exit" Click="Exit_Click"/>
                    </MenuItem>
                    <MenuItem Header="_View">
                        <MenuItem Header="_Full Screen" Click="FullScreen_Click" InputGesture="F"/>
                        <MenuItem Header="_Fit to Screen" Click="FitToScreen_Click"/>
                        <Separator/>
                        <MenuItem Header="Image _Metadata" IsChecked="{Binding ShowMetadata, Mode=TwoWay}" ToggleType="CheckBox"/>
                    </MenuItem>
                    <MenuItem Header="_Edit">
                        <MenuItem Header="_Edit Image" Click="EditImage_Click" IsEnabled="{Binding IsViewMode}"/>
                    </MenuItem>
                    <MenuItem Header="_Help">
                        <MenuItem Header="_About" Click="About_Click"/>
                    </MenuItem>
                </Menu>
            </Grid>
        </Border>

        <!-- Main Content Area -->
        <Grid Grid.Row="1" x:Name="MainGrid">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="300" MinWidth="150" MaxWidth="600"/>
            </Grid.ColumnDefinitions>

            <!-- Viewer Area -->
            <ScrollViewer Grid.Column="0" Name="MainScroll" 
                          HorizontalScrollBarVisibility="Hidden" 
                          VerticalScrollBarVisibility="Hidden" 
                          Background="Transparent">
                <Panel Name="ImagePanel" HorizontalAlignment="Center" VerticalAlignment="Center">
                    <LayoutTransformControl Name="ZoomTransform">
                        <LayoutTransformControl.LayoutTransform>
                            <ScaleTransform ScaleX="{Binding ZoomLevel}" ScaleY="{Binding ZoomLevel}"/>
                        </LayoutTransformControl.LayoutTransform>
                        <Panel>
                            <Image Source="{Binding ImageSource}" 
                                   IsVisible="{Binding ImageSource, Converter={x:Static ObjectConverters.IsNotNull}}"
                                   RenderOptions.BitmapInterpolationMode="HighQuality">
                                <Image.Transitions>
                                    <Transitions>
                                        <DoubleTransition Property="Opacity" Duration="0:0:0.3"/>
                                    </Transitions>
                                </Image.Transitions>
                            </Image>
                            
                            <TextBlock Text="{Binding ErrorMessage}" 
                                       IsVisible="{Binding ErrorMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                                       Foreground="#FF5555" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="SemiBold"/>
                            
                            <TextBlock Text="Drop an image here or press Ctrl+O" 
                                       IsVisible="{Binding ImagePath, Converter={x:Static StringConverters.IsNullOrEmpty}}"
                                       Foreground="#444444" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="18" FontWeight="SemiBold"/>
                        </Panel>
                    </LayoutTransformControl>
                </Panel>
            </ScrollViewer>

            <!-- GridSplitter for Resizing -->
            <GridSplitter Grid.Column="1" Width="1" Background="#222222" 
                          ResizeDirection="Columns" IsVisible="{Binding IsRightPaneVisible}"/>

            <!-- Side Panel (Right) -->
            <Border Grid.Column="2" Name="RightPane" Background="#0D0D0D" 
                    BorderBrush="#222222" BorderThickness="1,0,0,0"
                    IsVisible="{Binding IsRightPaneVisible}"
                    Padding="0">
                <Grid RowDefinitions="Auto,*">
                    <!-- Right Pane Header -->
                    <Border Grid.Row="0" Background="#111111" Padding="15,10" BorderBrush="#222222" BorderThickness="0,0,0,1">
                        <TextBlock Text="IMAGE INFO" x:Name="RightPaneHeader"
                                   Foreground="#AAAAAA" FontSize="11" FontWeight="Bold" LetterSpacing="1"/>
                    </Border>

                    <Panel Grid.Row="1" Margin="15">
                        <!-- Metadata View -->
                        <DockPanel IsVisible="{Binding IsViewMode}">
                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <ItemsControl ItemsSource="{Binding MetadataItems}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel Margin="0,0,0,14">
                                                <TextBlock Text="{Binding Label}" Foreground="#888888" FontSize="11" FontWeight="SemiBold" TextAlignment="Left" LetterSpacing="0.5"/>
                                                <TextBlock Text="{Binding Value}" Foreground="#FFFFFF" FontSize="13" FontWeight="SemiBold" TextWrapping="Wrap" Margin="0,5,0,0"/>
                                                <Rectangle Height="1" Fill="#1A1A1A" Margin="0,10,0,0"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </DockPanel>

                        <!-- Edit View -->
                        <DockPanel IsVisible="{Binding IsEditMode}">
                            <ScrollViewer VerticalScrollBarVisibility="Auto" DockPanel.Dock="Top">
                                <StackPanel Spacing="20">
                                    <!-- HSL Adjustments -->
                                    <StackPanel Spacing="8">
                                        <TextBlock Text="BRIGHTNESS" Foreground="#888888" FontSize="10" FontWeight="SemiBold" LetterSpacing="1"/>
                                        <Slider Minimum="0" Maximum="200" Value="{Binding Brightness}"/>
                                    </StackPanel>
                                    
                                    <StackPanel Spacing="8">
                                        <TextBlock Text="SATURATION" Foreground="#888888" FontSize="10" FontWeight="SemiBold" LetterSpacing="1"/>
                                        <Slider Minimum="0" Maximum="200" Value="{Binding Saturation}"/>
                                    </StackPanel>
                                    
                                    <StackPanel Spacing="8">
                                        <TextBlock Text="HUE" Foreground="#888888" FontSize="10" FontWeight="SemiBold" LetterSpacing="1"/>
                                        <Slider Minimum="0" Maximum="200" Value="{Binding Hue}"/>
                                    </StackPanel>
                                    
                                    <StackPanel Spacing="8">
                                        <TextBlock Text="CONTRAST" Foreground="#888888" FontSize="10" FontWeight="SemiBold" LetterSpacing="1"/>
                                        <Slider Minimum="-100" Maximum="100" Value="{Binding Contrast}"/>
                                    </StackPanel>

                                    <StackPanel Spacing="8">
                                        <TextBlock Text="BLUR" Foreground="#888888" FontSize="10" FontWeight="SemiBold" LetterSpacing="1"/>
                                        <Slider Minimum="0" Maximum="10" Value="{Binding BlurValue}"/>
                                    </StackPanel>

                                    <Rectangle Height="1" Fill="#222222" Margin="0,5"/>

                                    <TextBlock Text="FILTERS" Foreground="#888888" FontSize="11" FontWeight="SemiBold" LetterSpacing="1"/>
                                    <WrapPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                        <Button Classes="Modern" Content="Mono" Click="Filter_Click" Tag="Grayscale" Width="85" Margin="3" FontSize="11"/>
                                        <Button Classes="Modern" Content="Sepia" Click="Filter_Click" Tag="Sepia" Width="85" Margin="3" FontSize="11"/>
                                        <Button Classes="Modern" Content="Invert" Click="Filter_Click" Tag="Negate" Width="85" Margin="3" FontSize="11"/>
                                        <Button Classes="Modern" Content="Sketch" Click="Filter_Click" Tag="Charcoal" Width="85" Margin="3" FontSize="11"/>
                                        <Button Classes="Modern" Content="Edge" Click="Filter_Click" Tag="Edge" Width="85" Margin="3" FontSize="11"/>
                                    </WrapPanel>
                                </StackPanel>
                            </ScrollViewer>

                            <StackPanel DockPanel.Dock="Bottom" Margin="0,20,0,0" Spacing="10">
                                <Button Classes="Modern" Content="Save Changes" Click="SaveEdit_Click" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" Background="#2A2A2A"/>
                                <Button Classes="Modern" Content="Save As..." Click="SaveAsEdit_Click" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"/>
                                <Button Classes="Modern" Content="Discard" Click="DiscardEdit_Click" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" Foreground="#FF5555" Background="Transparent" BorderBrush="#442222"/>
                            </StackPanel>
                        </DockPanel>
                    </Panel>
                </Grid>
            </Border>
        </Grid>

        <!-- Bottom Area -->
        <Border Grid.Row="2" Background="#0A0A0A" BorderBrush="#222222" BorderThickness="0,1,0,0">
            <StackPanel IsVisible="{Binding IsViewMode}">
                <!-- Chevron Toggle -->
                <Button HorizontalAlignment="Center" 
                        Classes="Icon"
                        Click="ToggleControls_Click"
                        Padding="20,5">
                    <Path Data="{Binding ChevronData}" 
                          Fill="#666666" 
                          Width="12" Height="8" 
                          Stretch="Uniform">
                        <Path.Transitions>
                            <Transitions>
                                <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.2"/>
                            </Transitions>
                        </Path.Transitions>
                    </Path>
                </Button>
                
                <!-- Controls & Status Bar -->
                <StackPanel IsVisible="{Binding ShowControls}" Margin="15,0,15,15" Spacing="15">
                    <!-- Navigation Buttons -->
                    <Grid ColumnDefinitions="*,Auto,*">
                        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="10">
                            <!-- Zoom Out -->
                            <Button Classes="Modern" Click="ZoomOut_Click" Width="40" Height="40" Padding="0" ToolTip.Tip="Zoom Out">
                                 <Path Data="M 0 5 L 10 5 M 0 0 M 10 10" Stroke="#CCCCCC" StrokeThickness="2" Width="12" Height="12" Stretch="Uniform"/>
                            </Button>
                            
                            <!-- Prev -->
                            <Button Classes="Modern" Click="Prev_Click" Width="50" Height="40" Padding="0" ToolTip.Tip="Previous Image (Left Arrow)">
                                 <Path Data="M 10 0 L 0 5 L 10 10 Z" Fill="#CCCCCC" Width="12" Height="12" Stretch="Uniform"/>
                            </Button>

                            <!-- Reset Zoom / Zoom Info -->
                            <Button Classes="Modern" Click="ResetZoom_Click" MinWidth="100" Height="40" HorizontalContentAlignment="Center" ToolTip.Tip="Reset Zoom (Fit to Screen)">
                                 <TextBlock Text="{Binding ZoomLevel, StringFormat=\{0:P0\}}" Foreground="#FFFFFF" FontSize="12" FontWeight="Bold" HorizontalAlignment="Center"/>
                            </Button>

                            <!-- Next -->
                            <Button Classes="Modern" Click="Next_Click" Width="50" Height="40" Padding="0" ToolTip.Tip="Next Image (Right Arrow)">
                                 <Path Data="M 0 0 L 10 5 L 0 10 Z" Fill="#CCCCCC" Width="12" Height="12" Stretch="Uniform"/>
                            </Button>
                            
                            <!-- Zoom In -->
                            <Button Classes="Modern" Click="ZoomIn_Click" Width="40" Height="40" Padding="0" ToolTip.Tip="Zoom In">
                                 <Path Data="M 0 5 L 10 5 M 5 0 L 5 10" Stroke="#CCCCCC" StrokeThickness="2" Width="12" Height="12" Stretch="Uniform"/>
                            </Button>
                        </StackPanel>
                    </Grid>

                    <Border Background="#111111" CornerRadius="8" Padding="15,8" BorderBrush="#222222" BorderThickness="1">
                        <Grid ColumnDefinitions="*,Auto">
                            <TextBlock Text="{Binding ImagePath}" Foreground="#888888" FontSize="11" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="10" Margin="10,0,0,0">
                                <TextBlock Text="{Binding ImageWidth, StringFormat='\{0\}'}" Foreground="#AAAAAA" FontSize="11" VerticalAlignment="Center"/>
                                <TextBlock Text="×" Foreground="#888888" FontSize="11" VerticalAlignment="Center"/>
                                <TextBlock Text="{Binding ImageHeight, StringFormat='\{0\}'}" Foreground="#AAAAAA" FontSize="11" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                </StackPanel>
            </StackPanel>
        </Border>
    </Grid>
</Window>
