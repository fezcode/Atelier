<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Atelier.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
        x:Class="Atelier.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="Atelier"
        Icon="/Assets/atelier-icon.ico"
        Background="#0D0D0D"
        FontFamily="Inter, Segoe UI, Arial, sans-serif"
        DragDrop.AllowDrop="True">

    <Design.DataContext>
        <vm:MainWindowViewModel/>
    </Design.DataContext>

    <Grid RowDefinitions="Auto,*,Auto">
        <!-- Menu Bar -->
        <Menu Grid.Row="0" Background="#1A1A1A" IsVisible="{Binding ShowControls}" 
              FontFamily="Inter, Segoe UI, Arial, sans-serif" FontSize="12" FontWeight="Medium"
              Padding="5,2">
            <Menu.Styles>
                <Style Selector="MenuItem">
                    <Setter Property="Padding" Value="12,6"/>
                </Style>
            </Menu.Styles>
            <MenuItem Header="_File">
                <MenuItem Header="_Open..." Click="OpenFileName_Click" InputGesture="Ctrl+O"/>
                <MenuItem Header="_Save As..." Click="SaveAs_Click" InputGesture="Ctrl+S"/>
                <Separator/>
                <MenuItem Header="_Exit" Click="Exit_Click"/>
            </MenuItem>
            <MenuItem Header="_View">
                <MenuItem Header="_Full Screen" Click="FullScreen_Click" InputGesture="F"/>
                <MenuItem Header="_Fit to Screen" Click="FitToScreen_Click"/>
            </MenuItem>
            <MenuItem Header="_Edit">
                <MenuItem Header="_Edit Image" Click="EditImage_Click" IsEnabled="{Binding IsViewMode}"/>
            </MenuItem>
            <MenuItem Header="_Help">
                <MenuItem Header="_About" Click="About_Click"/>
            </MenuItem>
        </Menu>

        <!-- Main Content Area -->
        <Grid Grid.Row="1" x:Name="MainGrid">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="300" MinWidth="150" MaxWidth="600"/>
            </Grid.ColumnDefinitions>

            <!-- Viewer Area -->
            <ScrollViewer Grid.Column="0" Name="MainScroll" 
                          HorizontalScrollBarVisibility="Hidden" 
                          VerticalScrollBarVisibility="Hidden" 
                          Background="Transparent">
                <Panel Name="ImagePanel" HorizontalAlignment="Center" VerticalAlignment="Center">
                    <LayoutTransformControl Name="ZoomTransform">
                        <LayoutTransformControl.LayoutTransform>
                            <ScaleTransform ScaleX="{Binding ZoomLevel}" ScaleY="{Binding ZoomLevel}"/>
                        </LayoutTransformControl.LayoutTransform>
                        <Panel>
                            <Image Source="{Binding ImageSource}" 
                                   IsVisible="{Binding ImageSource, Converter={x:Static ObjectConverters.IsNotNull}}"
                                   RenderOptions.BitmapInterpolationMode="HighQuality"/>
                            
                            <TextBlock Text="{Binding ErrorMessage}" 
                                       IsVisible="{Binding ErrorMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                                       Foreground="#FF5555" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="SemiBold"/>
                            
                            <TextBlock Text="Drop an image here or press Ctrl+O" 
                                       IsVisible="{Binding ImagePath, Converter={x:Static StringConverters.IsNullOrEmpty}}"
                                       Foreground="#444444" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="18"/>
                        </Panel>
                    </LayoutTransformControl>
                </Panel>
            </ScrollViewer>

            <!-- GridSplitter for Resizing -->
            <GridSplitter Grid.Column="1" Width="4" Background="#333333" 
                          ResizeDirection="Columns" IsVisible="{Binding ShowControls}"/>

            <!-- Side Panel (Right) -->
            <Border Grid.Column="2" Background="#1A1A1A" 
                    BorderBrush="#333333" BorderThickness="1,0,0,0"
                    IsVisible="{Binding ShowControls}"
                    Padding="10">
                <Panel>
                    <!-- Metadata View -->
                    <DockPanel IsVisible="{Binding IsViewMode}">
                        <TextBlock DockPanel.Dock="Top" Text="IMAGE METADATA" Foreground="#666666" FontSize="10" FontWeight="Bold" LetterSpacing="1" Margin="5,0,0,10"/>
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <ItemsControl ItemsSource="{Binding MetadataItems}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Margin="5,2,5,8">
                                            <TextBlock Text="{Binding Label}" Foreground="#555555" FontSize="10" FontWeight="Bold"/>
                                            <TextBlock Text="{Binding Value}" Foreground="#DDDDDD" FontSize="11" TextWrapping="Wrap" Margin="0,2,0,0"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </DockPanel>

                    <!-- Edit View -->
                    <DockPanel IsVisible="{Binding IsEditMode}">
                        <StackPanel DockPanel.Dock="Top">
                            <Grid ColumnDefinitions="*,Auto">
                                <TextBlock Text="EDIT IMAGE" Foreground="#666666" FontSize="10" FontWeight="Bold" LetterSpacing="1" Margin="5,0,0,10" VerticalAlignment="Center"/>
                                <Button Grid.Column="1" Click="DiscardEdit_Click" Background="Transparent" BorderThickness="0" Padding="5">
                                    <Path Data="M 0 0 L 10 10 M 10 0 L 0 10" Stroke="#666666" StrokeThickness="2"/>
                                </Button>
                            </Grid>
                            
                            <Separator Background="#333333" Margin="0,5,0,15"/>
                            
                            <!-- HSL Adjustments -->
                            <TextBlock Text="BRIGHTNESS" Foreground="#555555" FontSize="9" FontWeight="Bold" Margin="5,0,0,2"/>
                            <Slider Minimum="0" Maximum="200" Value="{Binding Brightness}" Margin="5,0,5,10"/>
                            
                            <TextBlock Text="SATURATION" Foreground="#555555" FontSize="9" FontWeight="Bold" Margin="5,0,0,2"/>
                            <Slider Minimum="0" Maximum="200" Value="{Binding Saturation}" Margin="5,0,5,10"/>
                            
                            <TextBlock Text="HUE" Foreground="#555555" FontSize="9" FontWeight="Bold" Margin="5,0,0,2"/>
                            <Slider Minimum="0" Maximum="200" Value="{Binding Hue}" Margin="5,0,5,10"/>
                            
                            <TextBlock Text="CONTRAST" Foreground="#555555" FontSize="9" FontWeight="Bold" Margin="5,0,0,2"/>
                            <Slider Minimum="-100" Maximum="100" Value="{Binding Contrast}" Margin="5,0,5,10"/>

                            <TextBlock Text="BLUR" Foreground="#555555" FontSize="9" FontWeight="Bold" Margin="5,0,0,2"/>
                            <Slider Minimum="0" Maximum="10" Value="{Binding BlurValue}" Margin="5,0,5,10"/>

                            <TextBlock Text="FILTERS" Foreground="#666666" FontSize="10" FontWeight="Bold" Margin="5,10,0,10"/>
                            <WrapPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <Button Content="Mono" Click="Filter_Click" Tag="Grayscale" Width="60" Margin="2" FontSize="10"/>
                                <Button Content="Sepia" Click="Filter_Click" Tag="Sepia" Width="60" Margin="2" FontSize="10"/>
                                <Button Content="Invert" Click="Filter_Click" Tag="Negate" Width="60" Margin="2" FontSize="10"/>
                                <Button Content="Sketch" Click="Filter_Click" Tag="Charcoal" Width="60" Margin="2" FontSize="10"/>
                                <Button Content="Edge" Click="Filter_Click" Tag="Edge" Width="60" Margin="2" FontSize="10"/>
                            </WrapPanel>
                        </StackPanel>

                        <StackPanel DockPanel.Dock="Bottom" Margin="0,20,0,0" Spacing="10">
                            <Button Content="Save (Overwrite)" Click="SaveEdit_Click" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" Background="#2A2A2A"/>
                            <Button Content="Save As..." Click="SaveAsEdit_Click" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" Background="#2A2A2A"/>
                            <Button Content="Discard Changes" Click="DiscardEdit_Click" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" Foreground="#FF5555" Background="Transparent" BorderBrush="#442222"/>
                        </StackPanel>
                    </DockPanel>
                </Panel>
            </Border>
        </Grid>

        <!-- Bottom Area -->
        <StackPanel Grid.Row="2" Background="#1A1A1A" IsVisible="{Binding IsViewMode}">
            <!-- Chevron Toggle -->
            <Button HorizontalAlignment="Center" 
                    Background="Transparent" 
                    BorderThickness="0"
                    Click="ToggleControls_Click"
                    Padding="20,5">
                <Path Data="{Binding ChevronData}" 
                      Fill="#666666" 
                      Width="12" Height="8" 
                      Stretch="Uniform"/>
            </Button>
            
            <!-- Controls & Status Bar -->
            <StackPanel IsVisible="{Binding ShowControls}" Margin="10,0,10,10">
                <!-- Navigation Buttons with Icons (Using simple paths for icons) -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="20" Margin="0,0,0,10">
                    <Button Click="Prev_Click" Background="#2A2A2A" Padding="15,8" ToolTip.Tip="Previous Image (Left Arrow)">
                         <Path Data="M 10 0 L 0 5 L 10 10 Z" Fill="#CCCCCC" Width="10" Height="10" Stretch="Uniform"/>
                    </Button>
                    <Button Click="Next_Click" Background="#2A2A2A" Padding="15,8" ToolTip.Tip="Next Image (Right Arrow)">
                         <Path Data="M 0 0 L 10 5 L 0 10 Z" Fill="#CCCCCC" Width="10" Height="10" Stretch="Uniform"/>
                    </Button>
                </StackPanel>

                <Border Background="#111111" CornerRadius="4" Padding="10,5">
                    <Grid ColumnDefinitions="*,Auto">
                        <TextBlock Text="{Binding ImagePath}" Foreground="#888888" FontSize="11" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                        <Button Grid.Column="1" Click="ResetZoom_Click" Background="Transparent" BorderThickness="0" Padding="5,0" ToolTip.Tip="Reset Zoom (100%)">
                             <TextBlock Text="{Binding ZoomLevel, StringFormat='Zoom: {0:P0}'}" Foreground="#BBBBBB" FontSize="11" VerticalAlignment="Center" FontWeight="Medium"/>
                        </Button>
                    </Grid>
                </Border>
            </StackPanel>
        </StackPanel>
    </Grid>
</Window>
